{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "schedule": ["before 6am on Monday"],
  "prConcurrentLimit": 5,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Container image references with digest pinning, annotated with # renovate: or // renovate:. Captures tag as currentValue and sha256 as currentDigest for atomic updates.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Example:
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   IMAGE="ghcr.io/renovatebot/renovate:43.113.0@sha256:abc123..."
        //
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   image: ghcr.io/renovatebot/renovate:43.113.0@sha256:abc123...
        "(?:#|//) renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:packageName|lookupName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\n(?:\\s*\\w+(?:\\s+\\w+)*\\s*=\\s*[\"']?|\\s*\\w+:\\s+)[^:]+:(?<currentValue>[^\\s@\"']+)@(?<currentDigest>sha256:[a-f0-9]+)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Container image references with tag only (no digest), annotated with # renovate: or // renovate:. Matches key-value lines where the value is a registry/path:tag.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Example:
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   image: ghcr.io/renovatebot/renovate:43.113.0
        "(?:#|//) renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:packageName|lookupName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\n\\s*\\w+:\\s+[^:]+:(?<currentValue>[^\\s@\"']+)(?:[\"'\\s]|$)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Plain version strings annotated with # renovate: or // renovate:. Handles both assignment (KEY=) and key-value (key:) styles for any datasource.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Examples:
        //   # renovate: datasource=github-releases depName=renovatebot/renovate
        //   RENOVATE_VERSION="43.113.0"
        //
        //   # renovate: datasource=npm depName=renovate versioning=npm
        //   RENOVATE_NPM_VERSION=43.113.0
        "(?:#|//) renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:packageName|lookupName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\n(?:\\s*\\w+(?:\\s+\\w+)*\\s*=\\s*[\"']?|\\s*\\w+:\\s+[\"']?)(?<currentValue>[^\\s@\"'#:]+)(?:[\"'\\s]|$)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    }
  ]
}
