{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "schedule": ["before 6am on Monday"],
  "prConcurrentLimit": 5,
  "customManagers": [
    // Custom regex `# renovate:` managers to capture all kind of packages
    // Following: https://docs.renovatebot.com/modules/manager/regex/#required-capture-groups
    {
      "customType": "regex",
      "description": "Container image references with digest pinning (registry/image:1.2.3@shaabc123...), annotated with # renovate: or // renovate:. Captures tag as currentValue and sha256 as currentDigest for atomic updates.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Supported fields:
        //   datasource=<value>              (required)
        //   depName=<value>                 (required if no packageName)
        //   packageName=<value>             (required if no depName)
        //   versioning=<value>              (optional, default: semver-coerced)
        //   extractVersion=<regex>          (optional)
        //   registryUrl=<url>               (optional)
        //
        // Example:
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   IMAGE="ghcr.io/renovatebot/renovate:43.136@sha256:b8dd2bc412bcabfe641377548863d46d13ac36adaf12103ecb0420c4a1e23261"
        //
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   image: ghcr.io/renovatebot/renovate:43.136@sha256:b8dd2bc412bcabfe641377548863d46d13ac36adaf12103ecb0420c4a1e23261
        "(?:#|//) renovate: datasource=(?<datasource>.*?)(?: depName=(?<depName>.+?))?(?: packageName=(?<packageName>.+?))?(?: versioning=(?<versioning>.+?))?(?: extractVersion=(?<extractVersion>.+?))?(?: registryUrl=(?<registryUrl>.+?))?\\n\\s*[^=:\\n]+[=:]\\s*[\"']?[^:]+:(?<currentValue>[^\\s@\"']+)@(?<currentDigest>[^\\s\"']+)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Container image references with tag only (no digest), annotated with # renovate: or // renovate:. Matches key-value lines where the value is a registry/path:tag.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Supported fields:
        //   datasource=<value>              (required)
        //   depName=<value>                 (required if no packageName)
        //   packageName=<value>             (required if no depName)
        //   versioning=<value>              (optional, default: semver-coerced)
        //   extractVersion=<regex>          (optional)
        //   registryUrl=<url>               (optional)
        //
        // Example:
        //   # renovate: datasource=docker depName=ghcr.io/renovatebot/renovate
        //   image: ghcr.io/renovatebot/renovate:43.136
        "(?:#|//) renovate: datasource=(?<datasource>.*?)(?: depName=(?<depName>.+?))?(?: packageName=(?<packageName>.+?))?(?: versioning=(?<versioning>.+?))?(?: extractVersion=(?<extractVersion>.+?))?(?: registryUrl=(?<registryUrl>.+?))?\\n\\s*[^=:\\n]+[=:]\\s*[\"']?[^:]+:(?<currentValue>[^\\s@\"']+)(?:[\"'\\s]|$)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "description": "Plain version strings annotated with # renovate: or // renovate:. Handles both assignment (KEY=) and key-value (key:) styles for any datasource.",
      "managerFilePatterns": ["/./"],
      "matchStrings": [
        // Supported fields:
        //   datasource=<value>              (required)
        //   depName=<value>                 (required if no packageName)
        //   packageName=<value>             (required if no depName)
        //   versioning=<value>              (optional, default: semver-coerced)
        //   extractVersion=<regex>          (optional)
        //   registryUrl=<url>               (optional)
        //
        // Examples:
        //   # renovate: datasource=github-releases depName=renovatebot/renovate
        //   RENOVATE_VERSION="43.136.0"
        //
        //   # renovate: datasource=npm depName=renovate versioning=npm
        //   RENOVATE_NPM_VERSION=43.129.0
        "(?:#|//) renovate: datasource=(?<datasource>.*?)(?: depName=(?<depName>.+?))?(?: packageName=(?<packageName>.+?))?(?: versioning=(?<versioning>.+?))?(?: extractVersion=(?<extractVersion>.+?))?(?: registryUrl=(?<registryUrl>.+?))?\\n\\s*[^=:\\n]+[=:]\\s*[\"']?(?<currentValue>[^\\s@\"'#:]+)(?:[\"'\\s]|$)",
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    }
  ],
  "packageRules": [
    {
      // The container-tag and version-string managers have no currentDigest capture group.
      // Renovate cannot write back a digest for those deps, so disable pin/pinDigest updates.
      // Digest pinning is handled by the container-digest manager, which captures currentDigest
      // and produces 'digest' updates (not 'pin'/'pinDigest'), so it is unaffected by this rule.
      "description": "Disable digest pinning for regex manager deps without a currentDigest capture group",
      "matchManagers": ["regex"],
      "matchUpdateTypes": ["pin", "pinDigest"],
      "enabled": false
    },
    {
      // The kustomize manager sets pinDigests: false on OCI helmCharts during extraction:
      // https://github.com/renovatebot/renovate/blob/930cf6633ccf38f3578cb112c7ad42c7f99e1cdb/lib/modules/manager/kustomize/extract.ts#L173
      // (see also: https://github.com/helm/helm/issues/10312, https://github.com/helm/helm/issues/10678)
      // However, config:best-practices includes docker:pinDigests which matches all docker datasource
      // deps and overrides that extractor-level setting. This rule restores the intended behaviour
      // by explicitly disabling pin/pinDigest updates for kustomize HelmChart deps.
      "description": "Disable digest pinning for kustomize OCI helmCharts",
      "matchManagers": ["kustomize"],
      "matchDepTypes": ["HelmChart"],
      "matchUpdateTypes": ["pin", "pinDigest"],
      "enabled": false
    }
  ]
}
