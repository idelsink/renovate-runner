{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>idelsink/renovate-runner"
  ],
  "packageRules": [
    {
      "description": "Group all Renovate version updates into a single PR",
      "matchDepNames": [
        "renovate",
        "renovatebot/renovate",
        "ghcr.io/renovatebot/renovate"
      ],
      "groupName": "renovate",
      "group": {
        "commitMessageExtra": "to {{newVersion}}"
      }
    }
  ]
}
